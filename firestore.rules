rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Clients ──────────────────────────────────────────────────────────────
    // Authenticated admins (dashboard) can read/write everything.
    // The client portal (/[slug]) is UNauthenticated by design (OTP-gated, not
    // Firebase Auth) — it never touches Firestore from the browser. All portal
    // reads/writes (slug lookup, accessCode OTP, dashboard data, updates) go
    // through Server Actions using the Admin SDK (src/app/actions.ts), which
    // bypasses these rules entirely. So `clients` and its subcollections can be
    // locked to authenticated-only without breaking the portal.
    // Previously `read: if true` + an unauthenticated `accessCode` update were
    // allowed here so the portal (running on the unauthenticated client SDK)
    // could work — that publicly exposed every client's PII and let anyone
    // read/overwrite the OTP access code. Fixed by migrating the portal to the
    // Admin SDK instead of loosening these rules.
    match /clients/{clientId} {
      allow read, write: if request.auth != null;
    }

    // Updates subcollection — admin dashboard only; portal reads via Admin SDK.
    match /clients/{clientId}/updates/{updateId} {
      allow read, write: if request.auth != null;
    }

    // Projects subcollection — admin dashboard only; portal reads via Admin SDK.
    match /clients/{clientId}/projects/{projectId} {
      allow read, write: if request.auth != null;
    }

    // All other client subcollections (tasks, notes, etc.) — authenticated only.
    match /clients/{clientId}/{path=**} {
      allow read, write: if request.auth != null;
    }

    // ── Other dashboard collections ──────────────────────────────────────────
    // leads: public funnel writes (contact form + newsletter) go through
    // Admin SDK only. Dashboard reads also via server actions — never the client.
    match /leads/{leadId} {
      allow read, write: if false;  // solo Admin SDK
    }

    // Portal OTP rate-limit (por IP) y log de eventos de seguridad — escritos
    // exclusivamente por src/app/actions.ts / security-log.ts vía Admin SDK.
    match /portalRateLimit/{docId}     { allow read, write: if false; }
    match /portalSecurityEvents/{docId} { allow read, write: if false; }
    match /tickets/{ticketId} {
      allow read, write: if request.auth != null;
    }
    match /finances/{financeId} {
      allow read, write: if request.auth != null;
    }
    match /activity/{activityId} {
      allow read, write: if request.auth != null;
    }
    match /tasks/{taskId} {
      allow read, write: if request.auth != null;
    }

    // ── CRM blob storage (dashboard state por user) ──────────────────
    match /crm_data/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // ── CRM document collections (scoped to owning user) ────────────
    // All share the same uid-based pattern: proposals, contracts,
    // invoices, strategies, ia_templates, discovery_sessions.
    match /proposals/{docId} {
      allow read, write: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
    }
    match /contracts/{docId} {
      allow read, write: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
    }
    match /invoices/{docId} {
      allow read, write: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
    }
    match /strategies/{docId} {
      allow read, write: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
    }
    match /ia_templates/{docId} {
      allow read, write: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
    }
    match /discovery_sessions/{docId} {
      allow read, write: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
    }

    // ── Notifications ─────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['read', 'readAt']);
      allow create, delete: if false;
    }

    // ── Blog (Admin SDK only; public reads filtered by status) ────
    match /blogBriefs/{briefId} {
      allow read, write: if false;  // solo Admin SDK
    }

    match /blogPosts/{postId} {
      allow read: if resource.data.status == 'published'
                  && resource.data.seo.noindex == false;
      allow write: if false;  // solo Admin SDK
    }

    // ═══════════════════════════════════════════════════════════════
    // Crypto Intelligence — Admin SDK only
    // Estas colecciones se escriben y leen exclusivamente desde el
    // backend (Server Actions + cron endpoints + bot de Telegram) vía
    // firebase-admin. El Cliente NO debe tener acceso directo.
    // ═══════════════════════════════════════════════════════════════
    match /alertRules/{docId}                   { allow read, write: if false; }
    match /alerts/{docId}                       { allow read, write: if false; }
    match /cryptoIntelLogs/{docId}              { allow read, write: if false; }
    match /telegramUsers/{docId}                { allow read, write: if false; }
    match /telegramSessions/{docId}             { allow read, write: if false; }
    match /prices/{docId}                       { allow read, write: if false; }
    match /priceSnapshots/{docId}/{path=**}     { allow read, write: if false; }

    // ═══════════════════════════════════════════════════════════════
    // Public Funnel — Admin SDK only
    // Written exclusively by Server Actions (submitContactForm,
    // subscribeToNewsletterAction) via firebase-admin. Inspect via
    // the Firebase console or admin-side server actions; the JS
    // client is never authorized to touch these collections.
    // ═══════════════════════════════════════════════════════════════
    match /newsletterSubscribers/{docId}        { allow read, write: if false; }
    match /rateLimit/{docId}                    { allow read, write: if false; }
    match /systemAlerts/{docId}                 { allow read, write: if false; }

    // Auth brute-force lockout — Admin SDK only
    match /authLockouts/{docId}                 { allow read, write: if false; }

    // ═══════════════════════════════════════════════════════════════
    // PixelBot WhatsApp Inbox — RETIRADA (Fase 5 rebanada 1, 2026-07-07).
    // pixelbot ya no proyecta a Firestore; el dashboard lee/escribe todo
    // vía /api/whatsapp-inbox/* → API interna de pixelbot (SQLite = source
    // of truth). Cerrado a cal/agua: nadie debe leer ni escribir aquí.
    // ⚠️ GATE DE DEPLOY: esta regla y el código de Fase A (pixelbot) +
    // Fase B (pixeltec-os) deben desplegarse JUNTOS. Si esta regla se
    // despliega ANTES que ese código, se rompe el inbox de WhatsApp en
    // producción (el dashboard viejo todavía lee tenants/** por onSnapshot).
    // ═══════════════════════════════════════════════════════════════
    match /tenants/{tenantId} {
      allow read, write: if false;
    }
    match /tenants/{tenantId}/{path=**} {
      allow read, write: if false;
    }

    // ═══════════════════════════════════════════════════════════════
    // WhatsApp atención — datos del dashboard (contacto, clasificación, notas).
    // Escritos por el admin autenticado via client SDK; el bot NUNCA los toca.
    // ═══════════════════════════════════════════════════════════════
    match /whatsappContacts/{phone} {
      allow read, write: if request.auth != null;
    }
    match /whatsappContacts/{phone}/{path=**} {
      allow read, write: if request.auth != null;
    }
  }
}
