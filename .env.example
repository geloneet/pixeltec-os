# Firebase Storage URLs
NEXT_PUBLIC_LOGO_URL=https://firebasestorage.googleapis.com/v0/b/studio-1487114664-78b63.firebasestorage.app/o/ptlogo2.png?alt=media
NEXT_PUBLIC_PROFILE_PHOTO_URL=https://firebasestorage.googleapis.com/v0/b/studio-1487114664-78b63.firebasestorage.app/o/fotodeperfil.jpg?alt=media

# Firebase Client SDK
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (required for session cookies / server-side auth)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# URL del vps-api (infra DevOps). Default: https://api.pixeltec.mx
VPS_API_URL=https://api.pixeltec.mx
# Secret compartido con el vps-api (dual-secret activo durante migración)
CRON_SECRET=change-me-use-a-strong-random-string

# ── Public funnel (contact form + newsletter) ─────────────────────────────────
# Resend transactional email
RESEND_API_KEY=re_change_me
RESEND_FROM_EMAIL=PixelTEC <noreply@pixeltec.mx>
PIXELTEC_TEAM_EMAIL=contacto@pixeltec.mx
# Opaque salt used to hash visitor IPs before persisting them
# (GDPR Art. 4(1) — raw IP is PII). 32+ random chars.
# Generate with:  openssl rand -base64 48
INTERNAL_IP_SALT=change-me-use-a-32-plus-char-random-string

# ── Admin access control ──────────────────────────────────────────────────────
# Comma-separated Firebase UIDs allowed to access /api/vps/* endpoints.
# Required for requireAdmin() in src/lib/auth-guards.ts
ADMIN_UIDS=

# ── Anthropic (Blog AI Pipeline) ──────────────────────────────────────────────
# Get your key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
# Model used for blog draft generation
ANTHROPIC_MODEL=claude-opus-4-7

# ── WhatsApp Cloud API (Meta) ─────────────────────────────────────────────────
# Replaces Twilio for all outbound WhatsApp. Get these from
# https://developers.facebook.com/apps/<APP_ID>/whatsapp-business/
WHATSAPP_ACCESS_TOKEN=                    # System User access token
WHATSAPP_PHONE_NUMBER_ID=                 # Phone Number ID
WHATSAPP_DEFAULT_TO=                       # Default recipient, ej 5213221378336
WHATSAPP_BUSINESS_ACCOUNT_ID=              # Optional, for logs
WHATSAPP_API_VERSION=v21.0         # Optional, defaults to v21.0
