# Firebase Storage URLs
NEXT_PUBLIC_LOGO_URL=https://firebasestorage.googleapis.com/v0/b/studio-1487114664-78b63.firebasestorage.app/o/ptlogo2.png?alt=media
NEXT_PUBLIC_PROFILE_PHOTO_URL=https://firebasestorage.googleapis.com/v0/b/studio-1487114664-78b63.firebasestorage.app/o/fotodeperfil.jpg?alt=media

# Firebase Client SDK
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (required for session cookies / server-side auth)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# URL del vps-api (infra DevOps). Default: https://api.pixeltec.mx
VPS_API_URL=https://api.pixeltec.mx
# Secret compartido con el vps-api (dual-secret activo durante migración)
CRON_SECRET=change-me-use-a-strong-random-string
