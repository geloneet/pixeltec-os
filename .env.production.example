# WhatsApp Cloud API — required by src/app/api/whatsapp/webhook/route.ts
WHATSAPP_APP_ID=your_app_id_from_meta_dashboard
WHATSAPP_APP_SECRET=your_app_secret_from_meta_dashboard
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=generate_with_openssl_rand_-hex_32
WHATSAPP_API_VERSION=v22.0

# PixelForge QA (F8) — preview `?pfqa=` (T3) + qa-runner (T6, servicio
# Playwright en docker-compose). QA_PREVIEW_TOKEN_SECRET debe ser el MISMO
# valor en `app` (firma/verifica el token) y en `qa-runner` (solo firma) —
# generar con `openssl rand -hex 32`. QA_INTERNAL_APP_URL es el origin
# interno que el runner navega (red `pixeltec-os-internal`, NO localhost).
# OJO: NUNCA `http://app:3000` — el hostname pelón `app` matchea la entrada
# HSTS-preload del TLD `.app` embebida en Chromium, que fuerza el upgrade a
# https:// y revienta con net::ERR_SSL_PROTOCOL_ERROR contra un puerto HTTP
# plano (verificado empíricamente en el cierre F8, 2026-07-22; no se puede
# apagar por flag). Usar el alias DNS del container_name, que sí navega:
# `http://pixeltec-os:3000`. Las claves R2 (R2_ENDPOINT/R2_ACCESS_KEY_ID/
# R2_SECRET_ACCESS_KEY/R2_BUCKET_NAME/R2_PUBLIC_URL) ya existen para `app` —
# el runner reusa las MISMAS vía `env_file: .env.production` en
# docker-compose.yml, no hace falta duplicarlas.
QA_PREVIEW_TOKEN_SECRET=generate_with_openssl_rand_-hex_32
QA_INTERNAL_APP_URL=http://pixeltec-os:3000
